;; classes.edn — canonical CONFIG/DATA for kami-autodrive per-vehicle-class presets.
;;
;; The drive.gftd.ai autonomy stack (GNC: guidance / navigation / control) scales
;; one shared loop by a small per-class config: a kinematic ENVELOPE
;; (`:autodrive/limits`) and the autopilot TUNING that wraps it
;; (`:autodrive/autopilot`).
;;
;; ADR-0038: hot perception / planning / control stays native Rust; only this
;; init-time CONFIG/DATA moves to EDN. The limits/config are read ONCE when a
;; plant + Autopilot are constructed at boot (`VehicleClass::limits()`,
;; `AutopilotConfig::for_class(class)`), so they live here as the source of truth.
;; `kami-autodrive`'s compiled-in `VehicleClass::limits()` /
;; `AutopilotConfig::for_class()` remain the `builtin_*()` fallback and are
;; parity-tested against this file (every field == the real Rust).
;;
;; Keys are the four class ids: :car :ship :drone :aircraft. Field keywords are
;; hyphenated (`:max-speed` maps to the `max_speed` field). Ints coerce to floats.
{:autodrive/limits
 ;; Matches a mid-size sedan (kami-vehicle default).
 {:car {:max-speed 25.0 :max-accel 4.0 :max-decel 8.0 :wheelbase 2.7
        :max-steer 0.61 :turn-radius-ref 4.5 :footprint-radius 1.3}
  ;; Small civilian vessel: slow, wide turns, gentle accel.
  :ship {:max-speed 8.0 :max-accel 0.5 :max-decel 1.0 :wheelbase 30.0
         :max-steer 0.52 :turn-radius-ref 40.0 :footprint-radius 6.0}
  ;; Ground-projected agile multirotor.
  :drone {:max-speed 15.0 :max-accel 6.0 :max-decel 6.0 :wheelbase 0.5
          :max-steer 1.20 :turn-radius-ref 2.5 :footprint-radius 0.6}
  ;; Fixed-wing on taxi / coordinated-turn projection.
  :aircraft {:max-speed 60.0 :max-accel 3.0 :max-decel 4.0 :wheelbase 15.0
             :max-steer 0.35 :turn-radius-ref 250.0 :footprint-radius 8.0}}

 ;; Per-class autopilot tuning (`AutopilotConfig::for_class`). All four classes
 ;; share the same constants; only the derived fields vary:
 ;;   :limits         — pulled from `:autodrive/limits` for the same class
 ;;   :goal-tol       — limits.footprint-radius.max(1.0) (so a small footprint
 ;;                     still tolerates >=1m; authored here as the resolved value)
 ;;   :loiter-radius  — a non-stopping vehicle (the aircraft) orbits at this
 ;;                     radius instead of stopping; absent = a normal stopping
 ;;                     vehicle (None).
 ;; `:z-band` / `:camera-z-band` are `[lo hi]` pairs.
 :autodrive/autopilot
 {:car {:grid-half-extent 60.0 :grid-res 0.5 :z-band [-1.0 1.5] :replan-period 20
        :goal-tol 1.3 :emergency-cone 0.35 :lateral-accel 3.0 :brake-margin 1.6
        :dynamic-obstacles true :camera-z-band [0.3 2.5] :stuck-limit 0
        :recovery-ticks 60}
  :ship {:grid-half-extent 60.0 :grid-res 0.5 :z-band [-1.0 1.5] :replan-period 20
         :goal-tol 6.0 :emergency-cone 0.35 :lateral-accel 3.0 :brake-margin 1.6
         :dynamic-obstacles true :camera-z-band [0.3 2.5] :stuck-limit 0
         :recovery-ticks 60}
  :drone {:grid-half-extent 60.0 :grid-res 0.5 :z-band [-1.0 1.5] :replan-period 20
          :goal-tol 1.0 :emergency-cone 0.35 :lateral-accel 3.0 :brake-margin 1.6
          :dynamic-obstacles true :camera-z-band [0.3 2.5] :stuck-limit 0
          :recovery-ticks 60}
  :aircraft {:grid-half-extent 60.0 :grid-res 0.5 :z-band [-1.0 1.5] :replan-period 20
             :goal-tol 8.0 :emergency-cone 0.35 :lateral-accel 3.0 :brake-margin 1.6
             :dynamic-obstacles true :camera-z-band [0.3 2.5] :stuck-limit 0
             :recovery-ticks 60 :loiter-radius 200.0}}}
