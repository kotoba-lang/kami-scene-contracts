;; materials.edn — canonical CONFIG/DATA for kami-cam STOCK MATERIAL presets.
;;
;; ADR-0046 / ADR-0038: a material preset is init-time CONFIG — a small feed/speed
;; lookup (density g/cm^3 + Brinell hardness HB) read once when a CAM job seeds its
;; `Stock`. It just describes; nothing per-element-hot reads it. So it lives here as
;; the source of truth. kami-cam's compiled-in `CamMaterial::aluminum_6061()` … stay
;; as the `builtin_material()` fallback and are parity-tested against this file
;; (tests/materials_parity.rs — values are never transcribed, they are asserted `==`
;; the real `CamMaterial::*()`).
;;
;; ids + field keys use hyphens (idiomatic EDN keywords, e.g. :titanium-ti6al4v); the
;; loader maps each to `CamMaterial { name, density, hardness }`. Decimal literals
;; here parse to the same f64 as the Rust literals, so parity is exact.
{:cam/materials
 {;; Aluminum 6061-T6 — common machinable aluminium alloy.
  :aluminum-6061    {:name "Aluminum 6061-T6"   :density 2.70 :hardness 95.0}
  ;; AISI 1045 medium-carbon steel.
  :steel-1045       {:name "Steel 1045"         :density 7.87 :hardness 163.0}
  ;; Ti-6Al-4V aerospace titanium alloy.
  :titanium-ti6al4v {:name "Titanium Ti-6Al-4V" :density 4.43 :hardness 334.0}
  ;; ABS thermoplastic (injection molding / 3D printing stock).
  :abs-plastic      {:name "ABS Plastic"        :density 1.04 :hardness 10.0}
  ;; Red oak hardwood.
  :wood-oak         {:name "Oak (Red)"          :density 0.66 :hardness 6.0}}}
