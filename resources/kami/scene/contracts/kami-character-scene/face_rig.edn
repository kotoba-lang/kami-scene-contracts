;; face_rig.edn — canonical CONFIG/DATA for kami-character's MetaHuman FACS face rig.
;;
;; ADR-0046 / ADR-0038: the rig EVALUATION (graph eval → bone transforms) stays native
;; Rust (`kami-character::control_rig::ControlRig::evaluate`); only the init-time
;; DESCRIPTION — the FACS Action-Unit → bone mapping table that
;; `ControlRig::metahuman_face_rig()` builds from — moves to EDN here. Each row mirrors
;; one `add_au_bone(au, bone, axis, max-angle)` call (which expands to a
;; control → multiply → rotation-axis node triple). kami-character is untouched; its
;; `metahuman_face_rig()` stays the builtin fallback AND the parity oracle, and the
;; rebuilt rig's nodes are asserted node-for-node `==` it (tests/face_rig_parity.rs).
;;
;; MetaHuman / FACS reference (https://www.metahuman.com): 46 FACS Action Units drive
;; the 72-bone face rig; this preset wires the 19 AUs that map to discrete face bones.
{:character/face-rig
 {:au-bones
  ;; {:au <FACS action-unit / control name>  :bone <metahuman skeleton bone idx>
  ;;  :axis [x y z] (rotation axis)          :max-angle <radians at AU = 1.0>}
  ;; Eyelids (bones 13-16)
  [{:au "AU43_L" :bone 13 :axis [1.0 0.0 0.0] :max-angle -0.5}  ;; left upper eyelid close
   {:au "AU43_R" :bone 15 :axis [1.0 0.0 0.0] :max-angle -0.5}  ;; right upper eyelid close
   {:au "AU7_L"  :bone 14 :axis [1.0 0.0 0.0] :max-angle 0.3}   ;; left lower eyelid tighten
   {:au "AU7_R"  :bone 16 :axis [1.0 0.0 0.0] :max-angle 0.3}   ;; right lower eyelid tighten
   ;; Brows (bones 17-22)
   {:au "AU1"    :bone 17 :axis [1.0 0.0 0.0] :max-angle 0.3}   ;; inner brow raise
   {:au "AU2_L"  :bone 19 :axis [1.0 0.0 0.0] :max-angle 0.25}  ;; outer brow raise L
   {:au "AU2_R"  :bone 22 :axis [1.0 0.0 0.0] :max-angle 0.25}  ;; outer brow raise R
   {:au "AU4"    :bone 18 :axis [1.0 0.0 0.0] :max-angle -0.2}  ;; brow lower (mid)
   ;; Jaw (bone 8)
   {:au "AU26"   :bone 8  :axis [1.0 0.0 0.0] :max-angle 0.4}   ;; jaw drop
   {:au "AU30"   :bone 8  :axis [0.0 1.0 0.0] :max-angle 0.15}  ;; jaw sideways
   ;; Lip corners (bones 34-35)
   {:au "AU12_L" :bone 34 :axis [0.0 0.0 1.0] :max-angle 0.3}   ;; smile L
   {:au "AU12_R" :bone 35 :axis [0.0 0.0 1.0] :max-angle 0.3}   ;; smile R
   {:au "AU15_L" :bone 34 :axis [0.0 0.0 1.0] :max-angle -0.2}  ;; frown L
   {:au "AU15_R" :bone 35 :axis [0.0 0.0 1.0] :max-angle -0.2}  ;; frown R
   ;; Nostrils (bones 25-26)
   {:au "AU38_L" :bone 25 :axis [1.0 0.0 0.0] :max-angle 0.15}  ;; nostril dilate L
   {:au "AU38_R" :bone 26 :axis [1.0 0.0 0.0] :max-angle 0.15}  ;; nostril dilate R
   ;; Cheeks (bones 36-37)
   {:au "AU6_L"  :bone 36 :axis [1.0 0.0 0.0] :max-angle 0.2}   ;; cheek raise L
   {:au "AU6_R"  :bone 37 :axis [1.0 0.0 0.0] :max-angle 0.2}   ;; cheek raise R
   ;; Tongue (bone 44)
   {:au "AU19"   :bone 44 :axis [1.0 0.0 0.0] :max-angle 0.5}]}} ;; tongue out
