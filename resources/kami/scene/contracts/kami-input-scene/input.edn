;; Canonical default input-binding maps for kami-input (ADR-0040 data tier:
;; "input: device→action maps as EDN").
;;
;; Each entry mirrors one `kami_input::InputMap::{default_fps,default_graph}()`
;; builder. A map is an ORDERED vector of `[key-code action]` pairs — order
;; matters, because `InputMap::resolve` is first-match. These are parity-tested
;; == the real Rust (every (key, action), in order) in tests/input_parity.rs.
;;
;; key-code is the W3C KeyboardEvent.code string (e.g. "KeyW", "ArrowUp",
;; "Escape"). action is an Action keyword id (hyphenated): :move-up /
;; :move-down / :move-left / :move-right / :zoom-in / :zoom-out / :pan-start /
;; :pan-end / :pan-move / :primary / :secondary / :cancel / :confirm / :jump /
;; :sprint / :interact / :attack / :pause / :reset / :menu / :fullscreen.

{:input/maps
 {:fps   [["KeyW" :move-up]      ["ArrowUp" :move-up]
          ["KeyS" :move-down]    ["ArrowDown" :move-down]
          ["KeyA" :move-left]    ["ArrowLeft" :move-left]
          ["KeyD" :move-right]   ["ArrowRight" :move-right]
          ["Space" :jump]        ["ShiftLeft" :sprint]
          ["KeyE" :interact]     ["Escape" :pause]]

  :graph [["KeyW" :move-up]      ["ArrowUp" :move-up]
          ["KeyS" :move-down]    ["ArrowDown" :move-down]
          ["KeyA" :move-left]    ["ArrowLeft" :move-left]
          ["KeyD" :move-right]   ["ArrowRight" :move-right]
          ["Equal" :zoom-in]     ["NumpadAdd" :zoom-in]
          ["Minus" :zoom-out]    ["NumpadSubtract" :zoom-out]]}}
