;; Default kami.audio sound bank — the canonical drum/bass/SFX recipes a dance
;; scene starts from, in the same shape a scene's `:dance/audio :bank` uses.
;; EDN single-source (ADR-0038): this *is* the default bank — there is no Rust
;; `default_sound_bank()` mirror; a scene's `:dance/audio :bank` overrides/extends
;; these. Each cue is `{:wave :freq :to? :dur :gain}` (a kami.audio synth recipe).
{:dance/audio
 {:bank
  {:kick       {:wave "sine"     :freq 120.0  :to 45.0   :dur 0.18 :gain 0.5}
   :snare      {:wave "triangle" :freq 220.0  :to 160.0  :dur 0.12 :gain 0.35}
   :closed-hat {:wave "square"   :freq 8000.0 :to 6000.0 :dur 0.03 :gain 0.12}
   :open-hat   {:wave "square"   :freq 7000.0 :to 5000.0 :dur 0.12 :gain 0.12}
   :clap       {:wave "triangle" :freq 1200.0 :to 800.0  :dur 0.08 :gain 0.25}
   :crash      {:wave "square"   :freq 6000.0 :to 3000.0 :dur 0.5  :gain 0.15}
   :tom        {:wave "sine"     :freq 180.0  :to 90.0   :dur 0.2  :gain 0.3}
   :rim        {:wave "square"   :freq 1800.0 :to 1500.0 :dur 0.04 :gain 0.15}
   :bass       {:wave "sawtooth" :freq 80.0              :dur 0.25 :gain 0.4}
   :pad        {:wave "sine"     :freq 261.0             :dur 0.6  :gain 0.1}
   :coin       {:wave "square"   :freq 988.0  :to 1319.0 :dur 0.12 :gain 0.2}
   :whoosh     {:wave "sine"     :freq 800.0  :to 200.0  :dur 0.2  :gain 0.15}}}}
