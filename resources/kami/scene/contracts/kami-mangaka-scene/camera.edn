;; camera.edn — canonical CONFIG/DATA for kami-mangaka-scene's camera + manga
;; shot-grammar + three-point lighting presets (`camera.rs`).
;;
;; ADR-2605141200 / ADR-0038 data tier (see pose_lexicon.edn header for the
;; full rationale — same crate, same retirement/port circumstances).
;; `kami_mangaka_scene::camera::{CameraSpec::default, LightSpec::three_point_*}`
;; were the compiled-in sources of truth (`kami-mangaka-scene/src/camera.rs`).
;; These are read once per `MangakaScene::set_camera` / `add_light` call, not
;; touched by a hot per-frame solver, so they are safe to move to EDN.
;;
;; `:mangaka/shot-grammar` enumerates every `ShotGrammar` enum variant
;; (order matches the Rust `enum ShotGrammar` declaration) as hyphenated
;; keywords. `:mangaka/light-roles` likewise enumerates `LightRole`.
;;
;; `:mangaka/camera-defaults` mirrors `CameraSpec::default()`. `:dof` is
;; `nil` (`Option<Dof>::None` in the default); when present a `Dof` value is
;; `{:focus-distance-m .. :aperture ..}`.
;;
;; `:mangaka/light-presets` mirrors the three `LightSpec::three_point_*()`
;; builders. `:direction` is stored POST-`Vec3::normalize()` (the actual
;; resolved field value the builder returns, not the raw literal passed to
;; `Vec3::new(..)` before normalizing) — same convention as other authority
;; files storing resolved fields, not builder call-site literals (compare
;; kami-character-scene/hair.edn's resolved-field note). `:colour` is `[r g b]`
;; (note: this crate's `LightSpec.colour` is 3-component, unlike
;; kami-postfx-scene's 4-component `:color` fields — do not conflate).
{:mangaka/shot-grammar
 [:full-shot :medium-shot :closeup :over-shoulder :dutch :birds-eye :worms-eye]

 :mangaka/light-roles [:key :fill :rim :ambient]

 ;; Manga page aspect ~ 4:5.7 (B5) drives RenderOpts default in render.edn;
 ;; the camera default itself is aspect-agnostic (fov + eye/target/up only).
 :mangaka/camera-defaults
 {:eye [0.0 1.6 3.5]
  :target [0.0 1.4 0.0]
  :up [0.0 1.0 0.0]
  :fov-deg 35.0
  :roll-deg 0.0
  :dof nil
  :shot :medium-shot}

 :mangaka/light-presets
 {;; Key light — primary directional light, warm-white.
  :three-point-key
  {:role :key :direction [-0.557086 -0.742781 -0.371391]
   :colour [1.0 0.96 0.92] :intensity 4.0}
  ;; Fill light — softens key-light shadows, cool-white, lower intensity.
  :three-point-fill
  {:role :fill :direction [0.842701 -0.481543 -0.240772]
   :colour [0.86 0.92 1.0] :intensity 1.4}
  ;; Rim light — separates silhouette from background, neutral white.
  :three-point-rim
  {:role :rim :direction [0.102463 -0.204926 0.973399]
   :colour [1.0 1.0 1.0] :intensity 2.0}}}
