;; expression_lexicon.edn — canonical CONFIG/DATA for kami-mangaka-scene's
;; ARKit-style expression alias table (`lexicon::expression_preset()`).
;;
;; ADR-2605141200 / ADR-0038 data tier (see pose_lexicon.edn header for the
;; full rationale — same crate, same retirement/port circumstances).
;; `kami_mangaka_scene::lexicon::expression_preset()` was the compiled-in
;; source of truth (`kami-mangaka-scene/src/lexicon.rs`).
;;
;; Semantics (mirrors `expression_preset(name: &str) -> Expression`):
;;   1. Lower-case `name` (ASCII) before lookup — matching is case-insensitive
;;      ("JOY" and "joy" both resolve to :happy).
;;   2. Look up the lower-cased name in `:aliases`.
;;   3. Unknown / empty names fall back to `:default` (`Expression::Neutral`) —
;;      the Rust fn is total (`-> Expression`, not `Option`), never errors.
;;
;; `:canonical` enumerates every `Expression` enum variant (order matches the
;; Rust `enum Expression` declaration in pose.rs) as hyphenated keywords.
{:mangaka/expression-presets
 {:canonical [:neutral :happy :angry :sad :surprised :determined :pained :smirk]
  :default :neutral
  :aliases
  {"happy" :happy "joy" :happy "smile" :happy
   "angry" :angry "rage" :angry
   "sad" :sad "sorrow" :sad "grief" :sad
   "surprised" :surprised "surprise" :surprised "shock" :surprised
   "determined" :determined "resolve" :determined "focus" :determined
   "pained" :pained "pain" :pained "hurt" :pained
   "smirk" :smirk "smug" :smirk}}}
