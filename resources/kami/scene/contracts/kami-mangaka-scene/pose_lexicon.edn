;; pose_lexicon.edn — canonical CONFIG/DATA for kami-mangaka-scene's pose lexicon
;; (`lexicon::pose_preset()`).
;;
;; ADR-2605141200 (kami-mangaka-scene: headless 3D scene composition facade for
;; mangaka.etzhayyim.com — composes kami-vrm + kami-scene-graph + kami-render +
;; kami-postfx). Data-tier EDN extraction follows this repo's established
;; ADR-0038 pattern: rotations here are init-time CONFIG resolved once per
;; `MangakaScene::pose()` call (label -> coarse VRM bone rotation set), never
;; touched by a hot per-frame solver, so they are safe to move to EDN.
;; `kami_mangaka_scene::lexicon::pose_preset()` was the compiled-in source of
;; truth; kami-mangaka-scene's whole crate has since been retired from
;; kami-engine's working tree (recovered from git history for this port —
;; `kami-mangaka-scene/src/lexicon.rs`, 147 lines).
;;
;; Semantics (mirrors `pose_preset(label: &str) -> Option<Vec<BoneRotation>>`):
;;   1. Resolve `label` through `:aliases` to a canonical id when present,
;;      else use `label` itself.
;;   2. Look up the canonical id in `:presets`. A missing id (unknown label)
;;      means the Rust fn returned `None` — caller falls back to
;;      `PoseSpec::rest()` or explicit `BoneRotation` overrides.
;;   3. `:presets` values are ORDERED vectors of `{:bone :euler-deg}` pairs —
;;      order does not affect the result (each bone is set independently) but
;;      is preserved verbatim from the Rust match-arm slice for traceability.
;;
;; `:bone` is a VRM `HumanBoneName` id in camelCase (as `HumanBoneName::as_str()`
;; emits and `HumanBoneName::from_str()` parses — round-trips exactly, same
;; convention as kami-skeleton-scene/humanoid.edn's joint names).
;;
;; `:euler-deg` is `[x y z]` in DEGREES, intrinsic XYZ order. The Rust loader
;; converts via `Quat::from_euler(EulerRot::XYZ, x.to_radians(), y.to_radians(),
;; z.to_radians())` — apply the same conversion (`* PI / 180`, same axis order)
;; to reproduce the bit-exact `Quat` the compiled-in fn returns.
;;
;; Rotations are deliberately coarse — manga storytelling needs readable
;; silhouettes, not biomechanical fidelity (see lexicon.rs module doc). Finer
;; animation comes from the caller via explicit `PoseSpec.bones` overrides,
;; which take precedence over whatever preset is applied here.
{:mangaka/pose-presets
 {:aliases
  {"rest" "action.rest"
   "action.run" "action.dash"
   "action.attack" "action.swing"
   "action.impact" "action.hit"
   "action.flinch" "action.cower"
   "action.yell" "action.shout"
   "action.heroic" "action.stand_proud"}

  :presets
  {;; Idle / rest baselines.
   "action.rest" []
   "action.idle"
   [{:bone "spine" :euler-deg [0.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [0.0 0.0 70.0]}
    {:bone "rightUpperArm" :euler-deg [0.0 0.0 -70.0]}]

   ;; Locomotion.
   "action.dash"
   [{:bone "spine" :euler-deg [10.0 0.0 0.0]}
    {:bone "chest" :euler-deg [8.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [-45.0 0.0 75.0]}
    {:bone "leftLowerArm" :euler-deg [-65.0 0.0 0.0]}
    {:bone "rightUpperArm" :euler-deg [45.0 0.0 -75.0]}
    {:bone "rightLowerArm" :euler-deg [-65.0 0.0 0.0]}
    {:bone "leftUpperLeg" :euler-deg [-30.0 0.0 0.0]}
    {:bone "leftLowerLeg" :euler-deg [55.0 0.0 0.0]}
    {:bone "rightUpperLeg" :euler-deg [30.0 0.0 0.0]}
    {:bone "rightLowerLeg" :euler-deg [10.0 0.0 0.0]}]
   "action.walk"
   [{:bone "leftUpperArm" :euler-deg [-12.0 0.0 72.0]}
    {:bone "rightUpperArm" :euler-deg [12.0 0.0 -72.0]}
    {:bone "leftUpperLeg" :euler-deg [-10.0 0.0 0.0]}
    {:bone "rightUpperLeg" :euler-deg [10.0 0.0 0.0]}]

   ;; Combat / action beats.
   "action.swing"
   [{:bone "spine" :euler-deg [0.0 -20.0 0.0]}
    {:bone "chest" :euler-deg [0.0 -10.0 0.0]}
    {:bone "rightShoulder" :euler-deg [0.0 0.0 -20.0]}
    {:bone "rightUpperArm" :euler-deg [-90.0 0.0 -45.0]}
    {:bone "rightLowerArm" :euler-deg [-45.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [0.0 0.0 60.0]}
    {:bone "leftLowerArm" :euler-deg [-30.0 0.0 0.0]}]
   "action.hit"
   [{:bone "spine" :euler-deg [-15.0 0.0 0.0]}
    {:bone "chest" :euler-deg [-10.0 0.0 0.0]}
    {:bone "neck" :euler-deg [-10.0 0.0 0.0]}
    {:bone "head" :euler-deg [-15.0 10.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [-30.0 0.0 95.0]}
    {:bone "rightUpperArm" :euler-deg [-30.0 0.0 -95.0]}]

   ;; Reactions / emotion staging.
   "action.fall"
   [{:bone "spine" :euler-deg [-30.0 0.0 0.0]}
    {:bone "leftUpperLeg" :euler-deg [-70.0 0.0 0.0]}
    {:bone "rightUpperLeg" :euler-deg [-70.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [-60.0 0.0 110.0]}
    {:bone "rightUpperArm" :euler-deg [-60.0 0.0 -110.0]}]
   "action.cower"
   [{:bone "spine" :euler-deg [20.0 0.0 0.0]}
    {:bone "chest" :euler-deg [15.0 0.0 0.0]}
    {:bone "neck" :euler-deg [12.0 0.0 0.0]}
    {:bone "head" :euler-deg [12.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [-30.0 0.0 110.0]}
    {:bone "leftLowerArm" :euler-deg [-95.0 0.0 0.0]}
    {:bone "rightUpperArm" :euler-deg [-30.0 0.0 -110.0]}
    {:bone "rightLowerArm" :euler-deg [-95.0 0.0 0.0]}]
   "action.shout"
   [{:bone "spine" :euler-deg [-5.0 0.0 0.0]}
    {:bone "neck" :euler-deg [-15.0 0.0 0.0]}
    {:bone "head" :euler-deg [-20.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [-10.0 0.0 110.0]}
    {:bone "rightUpperArm" :euler-deg [-10.0 0.0 -110.0]}]
   "action.point"
   [{:bone "rightShoulder" :euler-deg [0.0 -10.0 -5.0]}
    {:bone "rightUpperArm" :euler-deg [0.0 0.0 -95.0]}
    {:bone "rightLowerArm" :euler-deg [0.0 0.0 0.0]}
    {:bone "rightIndexProximal" :euler-deg [0.0 0.0 0.0]}]
   "action.reach"
   [{:bone "spine" :euler-deg [-5.0 0.0 0.0]}
    {:bone "rightUpperArm" :euler-deg [0.0 0.0 -110.0]}
    {:bone "rightLowerArm" :euler-deg [0.0 0.0 5.0]}]
   "action.stand_proud"
   [{:bone "spine" :euler-deg [-2.0 0.0 0.0]}
    {:bone "chest" :euler-deg [-3.0 0.0 0.0]}
    {:bone "head" :euler-deg [-5.0 0.0 0.0]}
    {:bone "leftUpperArm" :euler-deg [0.0 0.0 78.0]}
    {:bone "rightUpperArm" :euler-deg [0.0 0.0 -78.0]}]}}}
