;; render.edn — canonical CONFIG/DATA for kami-mangaka-scene's render options,
;; render-pass bitflags, FX kinds, and scene-error taxonomy
;; (`render.rs`, `sim.rs`, `lib.rs::SceneError`).
;;
;; ADR-2605141200 / ADR-0038 data tier (see pose_lexicon.edn header for the
;; full rationale — same crate, same retirement/port circumstances).
;;
;; ── Scope: what is NOT in this file (adapter-only, intentionally unported) ──
;; The following kami-mangaka-scene modules are host/GPU/FFI adapters, not
;; scene-composition data or logic, and are out of scope for this EDN
;; authority (documented here, not reproduced):
;;   • `renderer.rs` (non-wasm) — the actual headless wgpu pipeline: uniform
;;     buffer layout, bind groups, `MangakaRenderer::render()` raymarch +
;;     readback. GPU-bound, no portable data tier.
;;   • `web.rs` (wasm) — `wasm-bindgen` browser preview surface
;;     (`ScenePreview`), driven by the editor's `requestAnimationFrame` loop.
;;   • `py.rs` (feature = "python") — PyO3 bindings (`PyMangakaScene`) exposed
;;     to `lg_mangaka.compose_scene_3d`; a thin JSON-in/JSON-out FFI shim over
;;     the same `set_background`/`set_camera`/`settle`/`render_multi` calls.
;;   • `shaders/render.wgsl` — sky gradient + per-pixel capsule raymarch
;;     fragment shader (fullscreen triangle vs. sky/ground/character
;;     silhouettes approximated as vertical capsules).
;;   • `shaders/outline.wgsl` — Sobel-style luminance-gradient edge pass over
;;     the base render, for manga-style inking.
;; `scene.rs`'s ECS/VRM-bound runtime (`MangakaScene::{load_character, pose,
;; tick, settle}`, spring-bone stepping, glTF node-world composition) is
;; likewise adapter/engine-state, not a data table, and is not mirrored here
;; — the *lexicon* it consults (pose_lexicon.edn / expression_lexicon.edn)
;; and the JSON-LD contract it emits (`to_jsonld`/`from_jsonld`, documented
;; below) are the portable parts.
;;
;; ── `:mangaka/render-defaults` mirrors `RenderOpts::default()` ──
;; Manga page aspect ~ 4:5.7 (B5); default dimensions approximate a panel
;; keyframe. `:passes` is the `ALL` bitflag (see `:mangaka/render-passes`).
;;
;; ── `:mangaka/render-passes` mirrors the `RenderPasses` bitflags (u32) ──
;; `:all` is the OR of the four single-bit flags, matching
;; `RenderPasses::ALL = BASE.bits() | DEPTH.bits() | OUTLINE.bits() | TONE.bits()`.
;;
;; ── `:mangaka/fx-kinds` mirrors the `FxKind` enum (sim.rs) ──
;; P0 skeleton: enum only in the Rust source (no per-kind data yet — wiring
;; to `kami-atmosphere`/`kami-pipelines` was deferred to P1–P2 and never
;; landed before the crate's retirement).
;;
;; ── `:mangaka/scene-errors` mirrors the `SceneError` enum (lib.rs) ──
;; `:message-template` is the `#[error("...")]` format string (thiserror);
;; `{0}` is the wrapped source-error string.
;;
;; ── `:mangaka/scene-jsonld-schema` documents `MangakaScene::to_jsonld()` /
;; `from_jsonld()` — the wire contract shared by the server, the PyO3 pod
;; bridge, and the wasm browser preview (`ScenePreview::{load_scene_jsonld,
;; to_scene_jsonld}`). `to_jsonld` is NOT a strict inverse of `from_jsonld`:
;; characters/props are scene-local runtime handles (VRM docs, hecs entities)
;; and are intentionally NOT rehydrated by `from_jsonld` — only
;; `environment`/`camera`/`lights` round-trip. This asymmetry is load-bearing
;; (see `tests/p1_smoke.rs::scene_jsonld_roundtrip_preserves_env_camera_lights`
;; parity test) and must not be "fixed" by a future consumer.
{:mangaka/render-defaults
 {:width 1024 :height 1448 :passes :all :seed 0}

 :mangaka/render-passes
 {:base 0x0001 :depth 0x0002 :outline 0x0004 :tone 0x0008 :all 0x000f}

 :mangaka/fx-kinds
 [:dust :hit-spark :splash :sparkle :smoke :speed-lines-3d]

 :mangaka/scene-errors
 [{:variant :vrm-decode :message-template "vrm decode failed: {0}"}
  {:variant :gltf-decode :message-template "gltf decode failed: {0}"}
  {:variant :render :message-template "render failed: {0}"}
  {:variant :jsonld :message-template "jsonld roundtrip failed: {0}"}]

 :mangaka/scene-jsonld-schema
 {:context "https://kami.etzhayyim.com/mangaka-scene/v1"
  :roundtrips [:environment :camera :lights]
  :emit-only [:characters :props]
  :fields
  {:characters [{:id :u32} {:rkey :string} {:pose-label "string?"}
                {:expression :mangaka/expression} {:root-xform :mangaka/transform}]
   :props [{:id :u32}]
   :camera "CameraSpec | null"
   :lights "[LightSpec]"
   :environment "EnvironmentSpec | null"}}}
